{
  "name": "monomi-cli",
  "version": "0.1.1",
  "description": "複数デバイス・複数プロジェクトで Claude Code を並行運用する際に、各プロジェクトの状態を横断確認できる CLI ダッシュボード",
  "keywords": [
    "claude-code",
    "dashboard",
    "cli",
    "monitoring",
    "tui"
  ],
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "bin": {
    "monomi": "dist/bin.js"
  },
  "files": [
    "dist",
    "reporter/monomi-report.sh",
    "CHANGELOG.md"
  ],
  "scripts": {
    "lint": "biome lint .",
    "format:check": "biome format . && prettier --check \"**/*.{md,mdx}\"",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json && node scripts/strip-dist-tests.js && chmod +x dist/bin.js",
    "preversion": "pnpm run test",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
