{
  "name": "@tep-lab/monomi",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "bin": {
    "monomi": "dist/cli.js"
  },
  "scripts": {
    "lint": "biome lint .",
    "format:check": "biome format . && prettier --check \"**/*.{md,mdx}\"",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "preversion": "pnpm run test",
    "version:patch": "pnpm version patch",
    "version:minor": "pnpm version minor",
    "version:major": "pnpm version major"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
